pkgname=veldmuis-branding
pkgver=20260306
pkgrel=10
pkgdesc="Branding assets and default theme configuration for Veldmuis Linux"
arch=("any")
url="https://github.com/ruannnebornman/veldmuis"
license=("MIT" "CC-BY-SA" "LGPL-2.0-or-later" "GPL-2.0-or-later")
source=(
  "rat1.png"
  "veldmuis-sddm.conf"
  "kdeglobals"
  "kwalletrc"
)
sha256sums=(
  "SKIP"
  "SKIP"
  "SKIP"
  "SKIP"
)

package() {
  install -Dm644 "${srcdir}/rat1.png" \
    "${pkgdir}/usr/share/veldmuis/wallpapers/rat1.png"
  install -Dm644 "${srcdir}/veldmuis-sddm.conf" \
    "${pkgdir}/etc/sddm.conf.d/veldmuis-sddm.conf"
  install -Dm644 "${srcdir}/kdeglobals" \
    "${pkgdir}/etc/xdg/kdeglobals"
  install -Dm644 "${srcdir}/kwalletrc" \
    "${pkgdir}/etc/xdg/kwalletrc"
  install -d "${pkgdir}/usr/share/wallpapers/VeldmuisDawn"
  cp -a "${startdir}/veldmuis-wallpaper/." \
    "${pkgdir}/usr/share/wallpapers/VeldmuisDawn/"
  install -d "${pkgdir}/usr/share/plasma/look-and-feel/org.veldmuis.desktop"
  cp -a "${startdir}/org.veldmuis.desktop/." \
    "${pkgdir}/usr/share/plasma/look-and-feel/org.veldmuis.desktop/"
  install -d "${pkgdir}/usr/share/sddm/themes"
  cp -a "${startdir}/veldmuis-breeze" \
    "${pkgdir}/usr/share/sddm/themes/veldmuis-breeze"
  install -Dm644 "${srcdir}/kwalletrc" \
    "${pkgdir}/etc/skel/.config/kwalletrc"
}
