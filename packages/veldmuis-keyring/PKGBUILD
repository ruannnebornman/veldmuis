pkgname=veldmuis-keyring
pkgver=20260305
pkgrel=7
pkgdesc="Pacman keyring for Veldmuis Linux"
arch=("any")
url="https://github.com/ruannnebornman/veldmuis"
license=("MIT")
depends=("pacman" "gnupg")
source=(
  "veldmuis.gpg"
  "veldmuis-trusted"
  "veldmuis-revoked"
)
sha256sums=(
  "b9b9c6bd63b445694524389435620eab20ed9b4d48e88cba37d2fc0916f7360b"
  "b5a9216dc618fa1284cbedd15d804a05333365c45ffa3d271548a4f956a3cdd6"
  "b1d5f6a854e7de7e658dd8f4c409755ba08149f7504bdbee9396d182fddd712d"
)

package() {
  install -Dm644 veldmuis.gpg "$pkgdir/usr/share/pacman/keyrings/veldmuis.gpg"
  install -Dm644 veldmuis-trusted \
    "$pkgdir/usr/share/pacman/keyrings/veldmuis-trusted"
  install -Dm644 veldmuis-revoked \
    "$pkgdir/usr/share/pacman/keyrings/veldmuis-revoked"
}
