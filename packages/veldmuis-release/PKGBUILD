  "254ba6439679c9fd8bb966759f62841abf0e9ca13413e7e6f120b6ea50f39e3a"
  "7746200f07620bb88a67cb4083527dc86a64d51b459f7a1786cce1caf69c5c08"
)

package() {
  install -Dm644 veldmuis-release "$pkgdir/etc/veldmuis-release"
  install -Dm644 veldmuis.conf "$pkgdir/etc/pacman.conf.d/veldmuis.conf"
  install -Dm644 os-release "$pkgdir/etc/os-release"
}
