+QList< FileSystem::Type >
+selectableFilesystemTypes( PartitionCoreModule* core, const QString& mountPoint, const QStringList& inUse )
+{
+    if ( !core )
+    {
+        return {};
+    }
+
+    if ( mountPoint.isEmpty() )
+    {
+        return core->dirFSRestrictLayout().anyAllowedFSTypes();
+    }
+
+    const QString efiMountPoint
+        = Calamares::JobQueue::instance()->globalStorage()->value( "efiSystemPartition" ).toString();
+    if ( PartUtils::isEfiSystem() && !efiMountPoint.isEmpty() && mountPoint == efiMountPoint )
+    {
+        return core->dirFSRestrictLayout().allowedFSTypes( mountPoint, inUse, false );
+    }
+
+    return core->dirFSRestrictLayout().allowedFSTypes( mountPoint, inUse, true );
+}
+
+void
+setSelectableFileSystems( PartitionCoreModule* core,
+                          QComboBox& combo,
+                          const QString& mountPoint,
+                          const QStringList& inUse,
+                          FileSystem::Type preferredType )
+{
+    const QList< FileSystem::Type > allowedFsTypes = selectableFilesystemTypes( core, mountPoint, inUse );
+    const QSet< FileSystem::Type > allowedFsSet( allowedFsTypes.cbegin(), allowedFsTypes.cend() );
+    const FileSystem::Type defaultFSType = defaultFilesystemType();
+    const bool wasBlocked = combo.blockSignals( true );
+
+    combo.clear();
+
+    int currentIndex = -1;
+    int defaultIndex = -1;
+    int comboIndex = 0;
+
+    auto addFsType = [ & ]( FileSystem::Type type )
+    {
+        auto fs = FileSystemFactory::map().value( type, nullptr );
+        if ( !fs || !isCreatableFilesystem( fs ) )
+        {
+            return;
+        }
+
+        combo.addItem( userVisibleFS( fs ) );
+        if ( type == preferredType )
+        {
+            currentIndex = comboIndex;
+        }
+        if ( type == defaultFSType )
+        {
+            defaultIndex = comboIndex;
+        }
+        ++comboIndex;
+    };
+
+    for ( auto fs : FileSystemFactory::map() )
+    {
+        if ( allowedFsSet.contains( fs->type() ) && !s_unmountableFS.contains( fs->type() ) )
+        {
+            addFsType( fs->type() );
+        }
+    }
+
+    for ( auto fs : FileSystemFactory::map() )
+    {
+        if ( s_unmountableFS.contains( fs->type() ) )
+        {
+            addFsType( fs->type() );
+        }
+    }
+
+    if ( currentIndex >= 0 )
+    {
+        combo.setCurrentIndex( currentIndex );
+    }
+    else if ( defaultIndex >= 0 )
+    {
+        combo.setCurrentIndex( defaultIndex );
+    }
+    else if ( combo.count() > 0 )
+    {
+        combo.setCurrentIndex( 0 );
+    }
+
+    combo.blockSignals( wasBlocked );
+}
