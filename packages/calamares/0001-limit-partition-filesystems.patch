+void
+EditExistingPartitionDialog::refreshFilesystemChoices( FileSystem::Type preferredType, bool includeCurrentFileSystem )
+{
+    if ( preferredType == FileSystem::Type::Unknown )
+    {
+        preferredType = FileSystem::typeForName( m_ui->fileSystemComboBox->currentText() );
+    }
+
+    setSelectableFileSystems( m_core,
+                              *( m_ui->fileSystemComboBox ),
+                              selectedMountPoint( m_ui->mountPointComboBox ),
+                              m_usedMountPoints,
+                              preferredType );
+
+    if ( includeCurrentFileSystem )
+    {
+        const QString currentFsName = userVisibleFS( m_partition->fileSystem() );
+        if ( m_ui->fileSystemComboBox->findText( currentFsName ) < 0 )
+        {
+            m_ui->fileSystemComboBox->addItem( currentFsName );
+        }
+        m_ui->fileSystemComboBox->setCurrentText( currentFsName );
+    }
+}
