#!/usr/bin/env bash

set -euo pipefail

graphics_conf_path="${VELDMUIS_CALAMARES_GRAPHICS_CONF_PATH:-/etc/calamares/modules/graphics.conf}"
skip_exec="${VELDMUIS_CALAMARES_SKIP_EXEC:-0}"
calamares_log_path="${VELDMUIS_CALAMARES_LOG_PATH:-/tmp/veldmuis-calamares-debug.log}"
bootstrap_log_path="${VELDMUIS_CALAMARES_BOOTSTRAP_LOG_PATH:-/tmp/veldmuis-calamares-bootstrap.log}"

detect_graphics() {
  if ! command -v lspci >/dev/null 2>&1; then
    return 0
  fi

  lspci -nn 2>/dev/null | grep -Ei 'VGA compatible controller|3D controller|Display controller' || true
}

write_header() {
  local default_id="$1"

  cat >"${graphics_conf_path}" <<EOF
---
mode: required
method: legacy

labels:
  step: "Graphics Driver"

default: ${default_id}

items:
EOF
}

write_all_open_source() {
  cat >>"${graphics_conf_path}" <<'EOF'
  - id: all-open-source
    name: "All open-source (default)"
    description: "Recommended default. Installs the broad open-source graphics stack for AMD, Intel, Nouveau, and general VM use."
    screenshot: "logomain.png"
EOF
}

write_default_open_source() {
  cat >>"${graphics_conf_path}" <<'EOF'
  - id: default-open-source
    name: "All open-source (default)"
    description: "Keeps the default open-source graphics stack from the base install. No extra vendor-specific packages are added."
    screenshot: "logomain.png"
EOF
}

write_amd_open_source() {
  cat >>"${graphics_conf_path}" <<'EOF'
  - id: amd-open-source
    name: "AMD / ATI (open-source)"
    description: "Installs the AMD / ATI open-source graphics stack."
    screenshot: "logomain.png"
EOF
}

write_intel_open_source() {
  cat >>"${graphics_conf_path}" <<'EOF'
  - id: intel-open-source
    name: "Intel (open-source)"
    description: "Installs the Intel open-source graphics stack."
    screenshot: "logomain.png"
EOF
}

write_nvidia_open_source() {
  cat >>"${graphics_conf_path}" <<'EOF'
  - id: nvidia-open-source
    name: "Nvidia (open-source nouveau driver)"
    description: "Uses the Nouveau stack for Nvidia hardware."
    screenshot: "logomain.png"
EOF
}

write_nvidia_580xx_dkms() {
  cat >>"${graphics_conf_path}" <<'EOF'
  - id: nvidia-580xx-dkms
    name: "Nvidia (580xx DKMS from AUR)"
    description: "Builds and installs nvidia-580xx-utils, nvidia-580xx-dkms, and lib32-nvidia-580xx-utils from the AUR during installation. Internet required."
    screenshot: "logomain.png"
EOF
}

prepare_logs() {
  rm -f "${calamares_log_path}" "${bootstrap_log_path}"
  touch "${calamares_log_path}"
}

main() {
  local graphics_lines
  local has_amd=0
  local has_intel=0
  local has_nvidia=0

  graphics_lines="$(detect_graphics)"

  if grep -qiE 'AMD/ATI|Advanced Micro Devices|AMD\b|ATI\b' <<<"${graphics_lines}"; then
    has_amd=1
  fi

  if grep -qi 'Intel' <<<"${graphics_lines}"; then
    has_intel=1
  fi

  if grep -qi 'NVIDIA' <<<"${graphics_lines}"; then
    has_nvidia=1
  fi

  if (( !has_amd && !has_intel && !has_nvidia )); then
    write_header default-open-source
    write_default_open_source
  else
    write_header all-open-source
    write_all_open_source
  fi

  if (( has_amd )); then
    write_amd_open_source
  fi

  if (( has_intel )); then
    write_intel_open_source
  fi

  if (( has_nvidia )); then
    write_nvidia_open_source
    write_nvidia_580xx_dkms
  fi

  prepare_logs

  exec > >(tee "${calamares_log_path}") 2>&1

  if [[ "${skip_exec}" == "1" ]]; then
    exit 0
  fi

  exec /usr/bin/calamares -d
}

main "$@"
