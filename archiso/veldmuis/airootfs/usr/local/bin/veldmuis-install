#!/usr/bin/env bash

set -euo pipefail

LIVE_REPO_ROOT="/opt/veldmuis/repo"
LIVE_REPO_BIND="/run/veldmuis-live-repo"
ARCHINSTALL_CONFIG="/tmp/veldmuis-archinstall-config.json"

log() {
  printf '[veldmuis-install] %s\n' "$*"
}

die() {
  printf '[veldmuis-install] ERROR: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

cleanup() {
  rm -f "${ARCHINSTALL_CONFIG}"
  if mountpoint -q "${LIVE_REPO_BIND}" 2>/dev/null; then
    umount "${LIVE_REPO_BIND}" || true
  fi
}

prepare_runtime_repo() {
  [[ -d "${LIVE_REPO_ROOT}/veldmuis-core/os/x86_64" ]] || die "Embedded Veldmuis repo not found at ${LIVE_REPO_ROOT}."

  install -d -m 0755 "${LIVE_REPO_BIND}"
  if ! mountpoint -q "${LIVE_REPO_BIND}"; then
    mount --bind "${LIVE_REPO_ROOT}" "${LIVE_REPO_BIND}"
  fi
}

write_archinstall_config() {
  python - <<'PY'
import json
import textwrap

config = {
    "bootloader_config": {
        "bootloader": "Systemd-boot",
        "removable": False,
        "uki": False,
    },
    "kernels": ["linux"],
    "ntp": True,
    "packages": ["veldmuis-desktop"],
    "mirror_config": {
        "custom_repositories": [
            {
                "name": "veldmuis-core",
                "url": "file:///run/veldmuis-live-repo/veldmuis-core/os/$arch",
                "sign_check": "Optional",
                "sign_option": "TrustAll",
            },
            {
                "name": "veldmuis-extra",
                "url": "file:///run/veldmuis-live-repo/veldmuis-extra/os/$arch",
                "sign_check": "Optional",
                "sign_option": "TrustAll",
            },
        ]
    },
    "profile_config": {
        "greeter": "sddm",
        "profile": {
            "custom_settings": {
                "KDE Plasma": {}
            },
            "details": ["KDE Plasma"],
            "main": "Desktop",
        },
    },
    "custom_commands": [
        textwrap.dedent(
            """\
            set -euo pipefail

            grep -qxF 'Include = /etc/pacman.conf.d/veldmuis.conf' /etc/pacman.conf || printf '\\nInclude = /etc/pacman.conf.d/veldmuis.conf\\n' >> /etc/pacman.conf

            sed -i '/^\\[veldmuis-core\\]/,/^$/d' /etc/pacman.conf
            sed -i '/^\\[veldmuis-extra\\]/,/^$/d' /etc/pacman.conf

            systemctl enable spice-vdagentd.service >/dev/null 2>&1 || true

            pacman -Q veldmuis-release veldmuis-branding veldmuis-desktop >/dev/null
            """
        )
    ],
}

with open("/tmp/veldmuis-archinstall-config.json", "w", encoding="utf-8") as fh:
    json.dump(config, fh, indent=2)
PY
}

main() {
  require_cmd archinstall
  require_cmd mount
  require_cmd python

  log "Supported Veldmuis install path:"
  log "  - KDE Plasma"
  log "  - SDDM"
  log "  - systemd-boot"
  log "  - Veldmuis package stack"
  log
  log "User-selectable during install:"
  log "  - disk layout and filesystem"
  log "  - hostname"
  log "  - locale and timezone"
  log "  - mirror region"
  log "  - GPU driver"
  log
  trap cleanup EXIT

  prepare_runtime_repo
  write_archinstall_config

  log "Launching archinstall..."

  archinstall --config "${ARCHINSTALL_CONFIG}"
}

main "$@"
